<%- include('../partials/head', { title }) %>
<%- include('../partials/nav') %>
<%
const parsePermissions = (permissions) => {
  if (Array.isArray(permissions)) {
    return permissions;
  }

  if (typeof permissions === 'string') {
    try {
      const parsed = JSON.parse(permissions);
      return Array.isArray(parsed) ? parsed : [];
    } catch {
      return permissions.split(',').map((item) => item.trim()).filter(Boolean);
    }
  }

  return [];
};
%>

<main class="container">
  <%- include('../partials/flash') %>
  <section class="page-heading">
    <div>
      <p class="eyebrow">Security administration</p>
      <h1>Scoped API Keys</h1>
      <p>Different client applications receive different permissions, reducing blast radius if a key is compromised.</p>
    </div>
  </section>

  <% if (createdSecret) { %>
    <div class="flash info">
      New API key secret: <code><%= createdSecret %></code>
      <strong>Copy now. It is stored as a hash and cannot be displayed again.</strong>
    </div>
  <% } %>

  <section class="card">
    <h2>Create API Key</h2>
    <form method="post" action="/admin/api-keys" class="grid-form compact">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>Name
        <input name="name" required placeholder="University Analytics Dashboard">
      </label>
      <label>Client type
        <select name="clientType">
          <option value="analytics_dashboard">Analytics Dashboard</option>
          <option value="mobile_ar_app">Mobile AR App</option>
          <option value="custom">Custom</option>
        </select>
      </label>
      <fieldset class="span-2 checkbox-group">
        <legend>Permissions</legend>
        <% permissions.forEach((permission) => { %>
          <label><input type="checkbox" name="permissions" value="<%= permission %>"> <%= permission %></label>
        <% }) %>
        <p class="hint">Leave permissions unchecked to use the default preset for the selected client type.</p>
      </fieldset>
      <button class="button span-2" type="submit">Create key</button>
    </form>
  </section>

  <section class="card">
    <h2>Existing Keys</h2>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Name</th><th>Type</th><th>Prefix</th><th>Permissions</th><th>Status</th><th>Last used</th><th></th></tr></thead>
        <tbody>
        <% apiKeys.forEach((key) => { %>
          <tr>
            <td><%= key.name %></td>
            <td><%= key.clientType %></td>
            <td><code><%= key.keyPrefix %></code></td>
            <td><%= parsePermissions(key.permissions).join(', ') || '-' %></td>
            <td><%= key.isActive ? 'Active' : 'Revoked' %></td>
            <td><%= key.lastUsedAt ? new Date(key.lastUsedAt).toLocaleString() : '-' %></td>
            <td>
              <% if (key.isActive) { %>
                <form method="post" action="/admin/api-keys/<%= key.id %>/revoke">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button class="danger small" type="submit">Revoke</button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</main>
<%- include('../partials/footer') %>
