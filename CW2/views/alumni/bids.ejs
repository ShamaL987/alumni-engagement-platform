<%- include('../partials/head', { title }) %>
<%- include('../partials/nav') %>

<%
const money = (value) => `£${Number(value || 0).toFixed(2)}`;

const bidFeedback = status?.bidFeedback || {
    status: 'no_bid',
    label: 'No bid placed',
    message: 'You have not placed a bid in this cycle.'
};

const cycleBidAttempts = status?.cycleBidAttempts ?? status?.bidAttemptsThisMonth ?? 0;
const cycleBidLimit = status?.cycleBidLimit ?? status?.monthlyBidLimit ?? 3;
const remainingCycleBidAttempts = status?.remainingCycleBidAttempts ?? status?.remainingBidAttempts ?? Math.max(cycleBidLimit - cycleBidAttempts, 0);
const monthlyWinLimit = status?.monthlyWinLimit ?? status?.monthlyLimit ?? 3;
const remainingWins = status?.remainingWins ?? Math.max(monthlyWinLimit - (status?.winsThisMonth || 0), 0);
const canSubmitBid = status?.bid ? status.canIncreaseBid : status.canPlaceNewBid;

const getBidStatusLabel = (bid) => {
    if (!bid) return '-';

    const isCurrentActiveBid =
            status?.bid &&
            Number(status.bid.id) === Number(bid.id) &&
            bid.status === 'active';

    if (isCurrentActiveBid) {
        return bidFeedback.label || bid.status;
    }

    return bid.status;
};

const getBidStatusClass = (bid) => {
    if (!bid) return '';

    const isCurrentActiveBid =
            status?.bid &&
            Number(status.bid.id) === Number(bid.id) &&
            bid.status === 'active';

    if (isCurrentActiveBid) {
        return bidFeedback.status || bid.status;
    }

    return bid.status;
};
%>

<main class="container narrow">
    <%- include('../partials/flash') %>

    <section class="card">
        <p class="eyebrow">Blind bidding</p>
        <h1>Bid for Alumni of the Day</h1>
        <p class="muted">
            The current highest bid is hidden. Each bid placement or increase uses one cycle attempt.
            Normal alumni receive 3 attempts per cycle, while alumni with a university session bonus receive 4 attempts per cycle.
            Monthly wins are still limited to 3.
        </p>

        <dl class="profile-facts">
            <div>
                <dt>Cycle ends</dt>
                <dd><%= new Date(status.cycle.endTime).toLocaleString() %></dd>
            </div>

            <div>
                <dt>Featured date</dt>
                <dd><%= status.cycle.featuredDate %></dd>
            </div>

            <div>
                <dt>Monthly wins</dt>
                <dd><%= status.winsThisMonth %> / <%= monthlyWinLimit %></dd>
            </div>

            <div>
                <dt>Remaining wins</dt>
                <dd><%= remainingWins %></dd>
            </div>

            <div>
                <dt>Cycle bid attempts</dt>
                <dd><%= cycleBidAttempts %> / <%= cycleBidLimit %></dd>
            </div>

            <div>
                <dt>Remaining cycle attempts</dt>
                <dd><%= remainingCycleBidAttempts %></dd>
            </div>

            <div>
                <dt>University session bonus</dt>
                <dd><%= status.attendedUniversitySession ? 'Enabled' : 'Not enabled' %></dd>
            </div>

            <div>
                <dt>Your active bid</dt>
                <dd><%= status.bid ? money(status.bid.bidAmount) : 'No bid yet' %></dd>
            </div>
        </dl>

        <div class="bid-status-card <%= bidFeedback.status %>">
            <h2><%= bidFeedback.label %></h2>
            <p><%= bidFeedback.message %></p>
        </div>

        <% if (!status.hasCompletedProfileForBidding) { %>
            <div class="flash error">
                Complete at least your full name and programme in <a href="/alumni/profile">My Profile</a> before placing a bid.
            </div>
        <% } else if (canSubmitBid) { %>
            <form action="/alumni/bids" method="post" class="form">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <label><%= status.bid ? 'New higher bid amount' : 'Bid amount' %>
                    <input name="bidAmount" type="number" min="1" step="0.01" required>
                </label>
                <button class="button" type="submit"><%= status.bid ? 'Increase bid' : 'Place blind bid' %></button>
            </form>
        <% } else { %>
            <div class="flash error">
                You have reached your cycle bid limit or monthly win limit.
                You can bid again in the next cycle if your monthly win limit is still available.
            </div>
        <% } %>
    </section>

    <section class="card">
        <h2>My bids in the current cycle</h2>
        <p class="muted">Only your own bid details are shown. Other alumni bid amounts remain hidden.</p>

        <div class="table-wrap">
            <table>
                <thead>
                <tr>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Placed/updated</th>
                    <th>Action</th>
                </tr>
                </thead>
                <tbody>
                <% if (!status.currentCycleBids || !status.currentCycleBids.length) { %>
                    <tr>
                        <td colspan="4" class="muted">You have not placed a bid in this active cycle yet.</td>
                    </tr>
                <% } %>

                <% (status.currentCycleBids || []).forEach((bid) => { %>
                    <tr>
                        <td><%= money(bid.bidAmount) %></td>
                        <td>
                <span class="tag bid-tag <%= getBidStatusClass(bid) %>">
                  <%= getBidStatusLabel(bid) %>
                </span>
                        </td>
                        <td><%= new Date(bid.updatedAt || bid.createdAt).toLocaleString() %></td>
                        <td>
                            <% if (bid.status === 'active') { %>
                                <form action="/alumni/bids/<%= bid.id %>/cancel" method="post">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <button class="danger small" type="submit">Cancel</button>
                                </form>
                            <% } else { %>
                                -
                            <% } %>
                        </td>
                    </tr>
                <% }) %>
                </tbody>
            </table>
        </div>
    </section>

    <section class="card">
        <h2>Bid activity history</h2>
        <p class="muted">Current active-cycle bids show whether they are winning or losing. Older bids show their final saved status.</p>

        <div class="table-wrap">
            <table>
                <thead>
                <tr>
                    <th>Cycle</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Updated</th>
                </tr>
                </thead>
                <tbody>
                <% if (!myBids || !myBids.length) { %>
                    <tr>
                        <td colspan="4" class="muted">No bid history yet.</td>
                    </tr>
                <% } %>

                <% (myBids || []).forEach((bid) => { %>
                    <tr>
                        <td><%= bid.cycle ? bid.cycle.featuredDate : '-' %></td>
                        <td><%= money(bid.bidAmount) %></td>
                        <td>
                <span class="tag bid-tag <%= getBidStatusClass(bid) %>">
                  <%= getBidStatusLabel(bid) %>
                </span>
                        </td>
                        <td><%= new Date(bid.updatedAt || bid.createdAt).toLocaleString() %></td>
                    </tr>
                <% }) %>
                </tbody>
            </table>
        </div>
    </section>
</main>

<%- include('../partials/footer') %>